/**
 * BC4 texture encoder.
 *
 * Description:
 * Provides `bc4Compress` function that converts images to BC4.
 *
 * Copyright: Timur Gafarov 2026
 * License: $(LINK2 https://boost.org/LICENSE_1_0.txt, Boost License 1.0).
 * Authors: Timur Gafarov
 */
module dagon.core.bc4;

import std.math;
import dlib.math.utils;

void bc4CompressBlock(ubyte* dst, ubyte* src)
{
    int vmin = src[0];
    int vmax = src[0];
    for (size_t i = 1; i < 16; ++i)
    {
        int v = src[i];
        vmin = min2(vmin, v);
        vmax = max2(vmax, v);
    }
    
    ubyte endpoint0 = cast(ubyte)vmax;
    ubyte endpoint1 = cast(ubyte)vmin;
    
    ubyte[8] palette;
    palette[0] = cast(ubyte)vmax;
    palette[1] = cast(ubyte)vmin;
    palette[2] = cast(ubyte)((vmax * 6 + vmin * 1) / 7);
    palette[3] = cast(ubyte)((vmax * 5 + vmin * 2) / 7);
    palette[4] = cast(ubyte)((vmax * 4 + vmin * 3) / 7);
    palette[5] = cast(ubyte)((vmax * 3 + vmin * 4) / 7);
    palette[6] = cast(ubyte)((vmax * 2 + vmin * 5) / 7);
    palette[7] = cast(ubyte)((vmax * 1 + vmin * 6) / 7);
    
    ubyte[16] selectors;
    for (size_t i = 0; i < 16; ++i)
    {
        int v = src[i];

        // Search for palette entry that minimizes the error
        ubyte bestSelector = 0;
        int bestError = abs(v - vmax);
        for (ubyte p = 0; p < palette.length; ++p)
        {
            int error = abs(v - palette[p]);
            if (error < bestError)
            {
                bestSelector = p;
                bestError = error;
            }
        }

        selectors[i] = bestSelector;
    }
    
    ulong packedSelectors = 0;
    for (int i = 0; i < selectors.length; ++i)
    {
        packedSelectors |= (cast(ulong)selectors[i] << (i * 3));
    }
    
    dst[0] = endpoint0;
    dst[1] = endpoint1;
    dst[2] = cast(ubyte)(packedSelectors >> 0);
    dst[3] = cast(ubyte)(packedSelectors >> 8);
    dst[4] = cast(ubyte)(packedSelectors >> 16);
    dst[5] = cast(ubyte)(packedSelectors >> 24);
    dst[6] = cast(ubyte)(packedSelectors >> 32);
    dst[7] = cast(ubyte)(packedSelectors >> 40);
}

/**
 * Compress image to BC4 to the memory buffer.
 * The buffer must be allocated and have the required capacity which is
 * calculated as numBlocksH * numBlocksV * 8.
 * BC4 block is 4x4 pixels.
 *
 * Params:
 *   output = Pointer to the output buffer.
 *   image  = Pointer to the input image.
 *   width  = Width of the image.
 *   height = Height of the image.
 *   numChannels = number of channels in the input image (only R channel is used).
 */
void bc4Compress(ubyte* output, ubyte* image, uint width, uint height, uint numChannels)
{
    ubyte[16] block; // 4x4 luminance values
    
    auto hblocks = max2(1, (width + 3) / 4);
    auto vblocks = max2(1, (height + 3) / 4);
    
    for (uint by = 0; by < vblocks; by++)
    {
        for (uint bx = 0; bx < hblocks; bx++)
        {
            // Fill 4x4 input block
            for (uint y = 0; y < 4; y++)
            {
                for (uint x = 0; x < 4; x++)
                {
                    uint srcx = bx * 4 + x;
                    uint srcy = by * 4 + y;
                    
                    if (srcx >= width)  srcx = width  - 1;
                    if (srcy >= height) srcy = height - 1;
                    uint srcIndex = (srcy * width + srcx) * numChannels;
                    
                    uint dstIndex = y * 4 + x;
                    block[dstIndex] = image[srcIndex]; // use R channel
                }
            }

            uint blockIndex = by * hblocks + bx;
            uint blockOffset = blockIndex * 8;
            bc4CompressBlock(output + blockOffset, block.ptr);
        }
    }
}
