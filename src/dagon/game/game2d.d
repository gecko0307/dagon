/**
 * Base class for 2D games and GUI applications.
 *
 * Description:
 * The `dagon.game.game2d` module defines the `Game2D` class, which serves
 * as a basic template for creating a 2D game application. It provides a HUD
 * (screen-aligned) renderer and handles window resize event for correctly
 * updating the viewport.
 *
 * Copyright: Timur Gafarov 2026
 * License: $(LINK2 https://boost.org/LICENSE_1_0.txt, Boost License 1.0).
 * Authors: Timur Gafarov
 */
module dagon.game.game2d;

import dlib.core.memory;

import dagon.core.time;
import dagon.render.hud;
import dagon.game.basegame;

class Game2D: BaseGame
{
    HUDRenderer renderer;
    
    this(uint w, uint h, bool fullscreen, string title, string[] args)
    {
        super(w, h, fullscreen, title, args);
        renderer = New!HUDRenderer(this, this);
        renderer.passHUD.clear = true;
    }
    
    override void onUpdate(Time t)
    {
        super.onUpdate(t);
        
        if (renderer && currentScene)
        {
            renderer.scene = currentScene;
            renderer.update(t);
        }
    }
    
    override void onRender()
    {
        if (currentScene)
        {
            if (currentScene.canRender && renderer)
            {
                renderer.render();
                currentScene.afterRender();
            }
        }
    }
    
    void resizeRenderers(int x, int y, int width, int height)
    {
        if (renderer)
            renderer.setViewport(x, y, width, height);
    }
    
    override void onResize(int width, int height)
    {
        resizeRenderers(0, 0, drawableWidth, drawableHeight);
    }
}
