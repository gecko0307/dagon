/**
 * Two-dimensional collision detection.
 *
 * Description:
 * The `dagon.collision.collision2d` module implements basic tools for
 * collision detection in 2D games. It assumes the world is represented using
 * line segments and the moving entities are represented using circles.
 * This suits best top-down games such as 2D action games or maze games.
 * It can be used for simple 3D games as well, for example, Doom-like shooters.
 * The module provides a spatial grid optimization for static segment data,
 * which makes collision detection almost free even for huge worlds.
 * The module doesn't provide collision response algorithm, but it is very easy
 * to implement.
 *
 * Copyright: Timur Gafarov 2026
 * License: $(LINK2 https://boost.org/LICENSE_1_0.txt, Boost License 1.0).
 * Authors: Timur Gafarov
 */
module dagon.collision.collision2d;

import std.algorithm;
import std.math;

import dlib.core.memory;
import dlib.core.ownership;
import dlib.math.vector;
import dlib.math.utils;
import dlib.container.array;

/// A 2D line segment. Basic static collision primitive.
struct Segment
{
    Vector2f a;
    Vector2f b;
}

/// An axis-aligned bounding box that defines an inclined quad.
struct Slope
{
    Vector2f pmin; // upper-left corner
    Vector2f pmax; // lower-right corner
    float h1; // (pmin.x, pmin.y) - upper-left corner height
    float h2; // (pmax.x, pmin.y) - upper-right corner height
    float h3; // (pmin.x, pmax.y) - lower-left corner height
    float h4; // (pmax.x, pmax.y) - lower-right corner height
}

/// Structure for storing 2D collision data.
struct Collision
{
    Vector2f n;
    float depth;
    bool fact;
}

/// Returns a point on a line segment that is closest to the given position.
Vector2f closestPointOnSegment(Vector2f pos, Segment seg)
{
    auto tangent = seg.b - seg.a;
    if (dot(pos - seg.a, tangent) <= 0)
        return seg.a; // pos is before a on the line
    
    if (dot(pos - seg.b, tangent) >= 0)
        return seg.b; // pos is after b on the line
    
    auto tangentNorm = tangent.normalized;
    auto relativePos = pos - seg.a;
    return seg.a + tangentNorm * dot(tangentNorm, relativePos);
}

/// Determines intersection between a 2D circle and a line segment.
bool collideCircleWithSegment(Vector2f circleCenter, float circleRadius, Segment seg, out Collision collision)
{
    Vector2f delta = circleCenter - closestPointOnSegment(circleCenter, seg);

    if (dot(delta, delta) > circleRadius * circleRadius)
        return false;
    
    collision = Collision(delta.normalized(), circleRadius - delta.length, true);
    return true;
}

/// Returns true if a point is inside a slope's bounding box.
bool pointInSlope(Slope s, Vector2f p)
{
    return (p.x >= s.pmin.x && p.x <= s.pmax.x &&
            p.y >= s.pmin.y && p.y <= s.pmax.y);
}

/// Returns interpolated slope height at a given position inside its bounds.
float getSlopeHeightAt(Slope s, Vector2f p)
{
    float w = s.pmax.x - s.pmin.x;
    float h = s.pmax.y - s.pmin.y;

    if (w <= 0 || h <= 0)
        return 0;

    float tx = clamp((p.x - s.pmin.x) / w, 0.0f, 1.0f);
    float ty = clamp((p.y - s.pmin.y) / h, 0.0f, 1.0f);
    
    float hTop = s.h1 * (1 - tx) + s.h2 * tx;
    float hBot = s.h3 * (1 - tx) + s.h4 * tx;
    
    return hTop * (1 - ty) + hBot * ty;
}

struct SpatialGridCell
{
    Array!size_t segmentIndices;
}

/**
 * Simple spatial hashing for 2D line segments.
 * Accelerates collision queries by reducing the number of potential colliding pairs.
 */
class SpatialGrid: Owner
{
    /// Global static segments array.
    Segment[] segments;
    
    float cellSize;
    float minX, minY, maxX, maxY;
    uint width = 0;
    uint height = 0;
    
    /// 2D array of spatial grid cells.
    SpatialGridCell[] cells;
    
    this(Segment[] segments, float cellSize, Owner owner)
    {
        super(owner);
        this.segments = segments;
        this.cellSize = cellSize;
        generate();
    }
    
    ~this()
    {
        if (cells.length)
        {
            foreach(cell; cells)
            {
                cell.segmentIndices.free();
            }
            
            Delete(cells);
        }
    }
    
    void generate()
    {
        if (segments.length == 0) return;
        
        minX = segments[0].a.x;
        minY = segments[0].a.y;
        maxX = minX;
        maxY = minY;
        
        foreach (s; segments)
        {
            minX = min(minX, min(s.a.x, s.b.x));
            minY = min(minY, min(s.a.y, s.b.y));
            maxX = max(maxX, max(s.a.x, s.b.x));
            maxY = max(maxY, max(s.a.y, s.b.y));
        }
        
        minX -= cellSize;
        minY -= cellSize;
        maxX += cellSize;
        maxY += cellSize;
        
        width = cast(uint)ceil((maxX - minX) / cellSize);
        height = cast(uint)ceil((maxY - minY) / cellSize);
        cells = New!(SpatialGridCell[])(width * height);
        
        foreach (i, s; segments)
        {
            int minCellX = cast(int)floor((min(s.a.x, s.b.x) - minX) / cellSize);
            int maxCellX = cast(int)floor((max(s.a.x, s.b.x) - minX) / cellSize);
            int minCellY = cast(int)floor((min(s.a.y, s.b.y) - minY) / cellSize);
            int maxCellY = cast(int)floor((max(s.a.y, s.b.y) - minY) / cellSize);
            
            minCellX -= 1;
            maxCellX += 1;
            minCellY -= 1;
            maxCellY += 1;
            
            // clamp to grid bounds
            minCellX = max(0, minCellX);
            maxCellX = min(cast(int)width - 1, maxCellX);
            minCellY = max(0, minCellY);
            maxCellY = min(cast(int)height - 1, maxCellY);

            foreach (cx; minCellX..maxCellX + 1)
            {
                foreach (cy; minCellY..maxCellY + 1)
                {
                    cells[cy * width + cx].segmentIndices.append(i);
                }
            }
        }
    }
    
    /// Returns segments array for a cell in a grid
    size_t[] getSegmentIndicesAtCell(uint x, uint y)
    {
        if (x < width && y < height)
            return cells[y * width + x].segmentIndices.data;
        else
            return [];
    }
    
    /// Returns segments array for a cell given a point in world space
    size_t[] getSegmentIndicesAt(Vector2f pos)
    {
        int cx = cast(int)floor((pos.x - minX) / cellSize);
        int cy = cast(int)floor((pos.y - minY) / cellSize);

        if (cx >= 0 && cx < cast(int)width && cy >= 0 && cy < cast(int)height)
            return cells[cy * width + cx].segmentIndices.data;
        else
            return [];
    }
}

