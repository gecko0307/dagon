module dagon.openworld.manager;

import dlib.core.memory;
import dlib.core.ownership;
import dlib.math.vector;

import dagon.core.time;
import dagon.graphics.entity;
import dagon.openworld.chunk;

class OpenWorldManager: Owner
{
   public:
    WorldChunk[] chunks;
    uint worldWidth;
    uint worldDepth;
    
    Entity traveler;
    Entity worldRoot;
    
    float chunkSize = 10.0f;
    int originX = 0;
    int originZ = 0;
    
    double stabilityDelay = 1.0;
    
    void delegate(Vector3f offset) onTravelerWrap;
    
   protected:
    int lastOriginX = 0;
    int lastOriginZ = 0;
    double lastMoveTime = 0.0;
    
   public:
    this(uint worldWidth, uint worldDepth, float chunkSize, Entity traveler, Owner owner)
    {
        super(owner);
        
        this.worldWidth = worldWidth;
        this.worldDepth = worldDepth;
        chunks = New!(WorldChunk[])(worldWidth * worldDepth);
        
        this.traveler = traveler;
        this.chunkSize = chunkSize;
    }
    
    ~this()
    {
        Delete(chunks);
    }
    
    uint chunkIndex(int x, int z)
    {
        int cx = x < 0 ? 0 : (x >= cast(int)worldWidth ? cast(int)worldWidth - 1 : x);
        int cz = z < 0 ? 0 : (z >= cast(int)worldDepth ? cast(int)worldDepth - 1 : z);
        return cast(uint)(cx + cz * cast(int)worldWidth);
    }
    
    void addChunk(WorldChunk chunk)
    {
        chunks[chunkIndex(chunk.x, chunk.z)] = chunk;
    }
    
    void updateChunks()
    {
        int xMin = originX - 1;
        int zMin = originZ - 1;
        int xMax = originX + 1;
        int zMax = originZ + 1;
        
        xMin = xMin < 0 ? 0 : xMin;
        zMin = zMin < 0 ? 0 : zMin;
        xMax = xMax >= cast(int)worldWidth ? cast(int)worldWidth - 1 : xMax;
        zMax = zMax >= cast(int)worldDepth ? cast(int)worldDepth - 1 : zMax;

        foreach(WorldChunk c; chunks)
        {
            if (c is null)
                continue;
            
            bool active =
                c.x >= xMin && c.x <= xMax &&
                c.z >= zMin && c.z <= zMax;
            
            if (active && !c.active)
            {
                c.active = true;
                c.onActivate();
            }
            else if (!active && c.active)
            {
                c.active = false;
                c.onDeactivate();
            }
        }
    }
    
    void update(Time t)
    {
        float tx = traveler.position.x;
        float tz = traveler.position.z;
        
        int worldDeltaX = 0;
        int worldDeltaZ = 0;
        
        if (tx > chunkSize * 0.5f)
            worldDeltaX = 1;
        else if (tx < -chunkSize * 0.5f)
            worldDeltaX = -1;
        
        if (tz > chunkSize * 0.5f)
            worldDeltaZ = 1;
        else if (tz < -chunkSize * 0.5f)
            worldDeltaZ = -1;
        
        if (worldDeltaX != 0 || worldDeltaZ != 0)
        {
            originX += worldDeltaX;
            originZ += worldDeltaZ;
            
            Vector3f wrapOffset = Vector3f(-worldDeltaX, 0.0f, -worldDeltaZ) * chunkSize;
            
            if (onTravelerWrap)
                onTravelerWrap(wrapOffset);
            
            foreach(WorldChunk c; chunks)
            {
                if (c)
                    c.onWrap(wrapOffset);
            }
            
            lastMoveTime = t.elapsed;
        }
        
        if ((originX != lastOriginX || originZ != lastOriginZ) &&
            (t.elapsed - lastMoveTime >= stabilityDelay))
        {
            updateChunks();
            
            lastOriginX = originX;
            lastOriginZ = originZ;
        }
    }
}
