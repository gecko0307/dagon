module ui;

import std.stdio;
import dagon;
import dagon.ext.imgui;
import editor;

struct EditorViewport
{
    ImVec2 position;
    ImVec2 size;
}

bool viewportChanged(EditorViewport oldvp, EditorViewport newvp)
{
    return (
        newvp.position.x != oldvp.position.x ||
        newvp.position.y != oldvp.position.y ||
        newvp.size.x != oldvp.size.x ||
        newvp.size.y != oldvp.size.y
    );
}

class EditorUI: EventListener
{
    Application application;
    EditorScene scene;
    ImGuiContext* igContext;
    ImGuiIO* io;
    ImFont* font;
    ImGuiViewport* viewport;
    
    EditorViewport editorViewport =
        EditorViewport(ImVec2(0, 0), ImVec2(0, 0));
    EditorViewport editorViewportPrevious =
        EditorViewport(ImVec2(0, 0), ImVec2(0, 0));
    
    Texture iconFile;
    
    this(Application application, EditorScene scene, string[] args)
    {
        super(application.eventManager, application);
        this.application = application;
        this.scene = scene;
        
        igContext = igCreateContext(null);
        igSetCurrentContext(igContext);
        io = igGetIO();
        io.ConfigFlags |= ImGuiConfigFlags.DockingEnable;
        io.ConfigWindowsMoveFromTitleBarOnly = true;
        ImWchar[] ranges = [
            0x0020, 0x00FF, // Basic Latin + Latin Supplement
            0x0370, 0x03FF, // Greek
            0x0400, 0x044F, // Cyrillic
            0
        ];
        font = ImFontAtlas_AddFontFromFileTTF(io.Fonts, "data/font/Roboto.ttf", 16, null, 
            ranges.ptr);
        igStyleColorsDark(null);
        ImGui_ImplSDL2_InitForOpenGL(application.window, application.glcontext);
        ImGuiOpenGLBackend.init("#version 400 core");
    }
    
    void onProcessEvent(SDL_Event* event)
    {
        ImGui_ImplSDL2_ProcessEvent(event);
    }
    
    bool capturesMouse() @property const
    {
        return io.WantCaptureMouse;
    }
    
    bool capturesKeyboard() @property const
    {
        return io.WantCaptureKeyboard;
    }
    
    void update(Time t)
    {
        processEvents();
        
        ImGuiOpenGLBackend.new_frame();
        ImGui_ImplSDL2_NewFrame();
        igNewFrame();
        
        viewport = cast(ImGuiViewport*)igGetMainViewport();
        
        ImGuiID mainDockSpaceId = igDockSpaceOverViewport(viewport, ImGuiDockNodeFlags.PassthruCentralNode);
        
        // Get free space size to update the render viewport
        ImGuiDockNode* centralNode = igDockBuilderGetCentralNode(mainDockSpaceId);
        if (centralNode)
        {
            editorViewport = EditorViewport(centralNode.Pos, centralNode.Size);
            if (viewportChanged(editorViewportPrevious, editorViewport))
            {
                int newWidth = cast(int)editorViewport.size.x;
                int newHeight = cast(int)editorViewport.size.y;
                if (newWidth > 0 && newHeight > 0)
                {
                    Event e;
                    e.type = EventType.CustomResize;
                    e.width = newWidth;
                    e.height = newHeight;
                    e.x = cast(int)editorViewport.position.x;
                    e.y = eventManager.drawableHeight - cast(int)editorViewport.position.y - e.height;
                    eventManager.queueEvent(e);
                }
                editorViewportPrevious = editorViewport;
            }
        }
        
        renderMenu();
        renderSettings();
        renderProperties();
        renderAssetBrowser();
        renderStatusBar();
        
        igRender();
    }
    
    void renderMenu()
    {
        igBeginMainMenuBar();
        if (igBeginMenu("File"))
        {
            igMenuItem("New scene");
            igMenuItem("Open...");
            igMenuItem("Save");
            igMenuItem("Save as...");
            igMenuItem("Exit");
            igEndMenu();
        }
        igEndMainMenuBar();
    }
    
    void renderSettings()
    {
        if (igBegin("Settings", null, ImGuiWindowFlags.NoCollapse))
        {
            if (igCollapsingHeader("Post-processing"))
            {
                if (igCheckbox("SSAO", &scene.ssaoEnabled))
                    scene.game.deferredRenderer.ssaoEnabled = scene.ssaoEnabled;
                if (scene.ssaoEnabled)
                {
                    igSliderFloat("SSAO radius", &scene.game.deferredRenderer.ssaoRadius, 0.01f, 1.0f, "%.2f");
                    igSliderInt("SSAO samples", &scene.game.deferredRenderer.ssaoSamples, 1, 30);
                    igSliderFloat("SSAO power", &scene.game.deferredRenderer.ssaoPower, 0.0f, 10.0f, "%.1f");
                    igSliderFloat("SSAO denoise", &scene.game.deferredRenderer.ssaoDenoise, 0.0f, 1.0f, "%.2f");
                }
                
                if (igCheckbox("DoF", &scene.depthOfFieldEnabled))
                    scene.game.postProcessingRenderer.depthOfFieldEnabled = scene.depthOfFieldEnabled;
                if (scene.depthOfFieldEnabled)
                {
                    if (!igCheckbox("Autofocus", &scene.game.postProcessingRenderer.autofocus))
                        igSliderFloat("Focal depth", &scene.game.postProcessingRenderer.focalDepth, 0.0f, 2.0f, "%.2f");
                    igSliderFloat("Focal length", &scene.game.postProcessingRenderer.focalLength, 0.0f, 10.0f, "%.2f");
                    igSliderFloat("F-Stop", &scene.game.postProcessingRenderer.fStop, 0.0f, 2.0f, "%.2f");
                }
                
                if (igCheckbox("Lens distortion", &scene.lensDistortionEnabled))
                    scene.game.postProcessingRenderer.lensDistortionEnabled = scene.lensDistortionEnabled;
                if (scene.lensDistortionEnabled)
                {
                    igSliderFloat("Dispersion", &scene.game.postProcessingRenderer.lensDistortionDispersion, 0.0f, 1.0f, "%.2f");
                    igSliderFloat("Scale", &scene.game.postProcessingRenderer.lensDistortionScale, 0.0f, 2.0f, "%.2f");
                }
                
                if (igCheckbox("Glow", &scene.glowEnabled))
                    scene.game.postProcessingRenderer.glowEnabled = scene.glowEnabled;
                if (scene.glowEnabled)
                {
                    if (igSliderInt("Glow radius", &scene.glowRadius, 0, 10))
                        scene.game.postProcessingRenderer.glowRadius = scene.glowRadius;
                    igSliderFloat("Glow threshold", &scene.game.postProcessingRenderer.glowThreshold, 0.0f, 2.0f, "%.2f");
                    igSliderFloat("Glow intensity", &scene.game.postProcessingRenderer.glowIntensity, 0.0f, 1.0f, "%.2f");
                }

                if (igCheckbox("Motion blur", &scene.motionBlurEnabled))
                    scene.game.postProcessingRenderer.motionBlurEnabled = scene.motionBlurEnabled;
                if (scene.motionBlurEnabled)
                {
                    uint samplesMin = 1;
                    uint samplesMax = 30;
                    igSliderScalar("Blur samples", ImGuiDataType.U32, &scene.game.postProcessingRenderer.motionBlurSamples, &samplesMin, &samplesMax);
                    uint framerateMin = 1;
                    uint framerateMax = 60;
                    igSliderScalar("Framerate", ImGuiDataType.U32, &scene.game.postProcessingRenderer.motionBlurFramerate, &framerateMin, &framerateMax);
                    igSliderFloat("Randomness", &scene.game.postProcessingRenderer.motionBlurRandomness, 0.0f, 1.0f, "%.2f");
                    igSliderFloat("Min distance", &scene.game.postProcessingRenderer.motionBlurMinDistance, 0.0f, 1.0f, "%.2f");
                    igSliderFloat("Max distance", &scene.game.postProcessingRenderer.motionBlurMaxDistance, 0.0f, 1.0f, "%.2f");
                    igSliderFloat("Radial blur", &scene.game.postProcessingRenderer.radialBlurAmount, 0.0f, 1.0f, "%.2f");
                }
                
                if (igCombo_Str("Tonemapper", &scene.tonemapper, "None\0Reinhard\0Uncharted\0ACES\0Filmic\0Reinhard2\0Unreal\0"))
                    scene.game.postProcessingRenderer.tonemapper = cast(Tonemapper)scene.tonemapper;
                igSliderFloat("Exposure", &scene.game.postProcessingRenderer.exposure, 0.0f, 2.0f, "%.1f");

                if (igCheckbox("FXAA antialiasing", &scene.fxaaEnabled))
                    scene.game.postProcessingRenderer.fxaaEnabled = scene.fxaaEnabled;
            }
            igEnd();
        }
    }

    void renderProperties()
    {
        if (igBegin("Entity", null, ImGuiWindowFlags.NoCollapse))
        {
            if (igCollapsingHeader("Options"))
            {
                if (scene.selectedEntity)
                {
                    igCheckbox("Visible", &scene.selectedEntity.visible);
                    igCheckbox("Casts shadow", &scene.selectedEntity.castShadow);
                    igCheckbox("Solid", &scene.selectedEntity.solid);
                    igCheckbox("Dynamic", &scene.selectedEntity.dynamic);
                    igCheckbox("Decal", &scene.selectedEntity.decal);
                    igCheckbox("Transparent", &scene.selectedEntity.transparent);
                    igSliderFloat("Entity opacity", &scene.selectedEntity.opacity, 0.0f, 1.0f, "%.3f");
                }
            }

            if (igCollapsingHeader("Transformation"))
            {
                if (scene.selectedEntity)
                {
                    igInputFloat3("Position XYZ", &scene.selectedEntity.position.arrayof);
                    igInputFloat4("Rotation XYZW", &scene.selectedEntity.rotation.arrayof);
                    igInputFloat3("Scaling XYZ", &scene.selectedEntity.scaling.arrayof);
                }
            }

            if (igCollapsingHeader("Material"))
            {
                igButton("Material", ImVec2(100, 100));
                if (igIsItemClicked(ImGuiMouseButton.Left))
                    igOpenPopup("Materials");
                if (igBeginPopup("Materials", ImGuiWindowFlags.AlwaysAutoResize))
                {
                    igSetCursorPosX(400);
                    igSetCursorPosX(0.0f);
                    renderMaterialBrowser();
                    igEndPopup();
                }
                
                if (igBeginDragDropTarget())
                {
                    const ImGuiPayload* payload = igAcceptDragDropPayload("ASSET");
                    if (payload)
                    {
                        int data = *cast(int*)payload.Data;
                        writeln("Drop asset ", data);
                    }
                    igEndDragDropTarget();
                }

                if (scene.selectedEntity && scene.selectedEntity.material)
                {
                    Material material = scene.selectedEntity.material;
                    igColorEdit4("Base color", &material.baseColorFactor.arrayof, ImGuiColorEditFlags.Float);
                    igSliderFloat("Roughness", &material.roughnessFactor, 0.0f, 1.0f, "%.3f");
                    igSliderFloat("Metallic", &material.metallicFactor, 0.0f, 1.0f, "%.3f");
                    //igSliderFloat("Specularity", &material.specularity, 0.0f, 1.0f, "%.3f");
                    igColorEdit4("Emission", &material.emissionFactor.arrayof, ImGuiColorEditFlags.Float);
                    igInputFloat("Emission energy", &material.emissionEnergy);
                    igCombo_Str("BlendMode", &material.blendMode, "Opaque\0Transparent\0Additive\0");
                    igSliderFloat("Opacity", &material.opacity, 0.0f, 1.0f, "%.3f");
                    igSliderFloat("Alpha test threshold", &material.alphaTestThreshold, 0.0f, 1.0f, "%.3f");
                    igCheckbox("Shadeless", &material.shadeless);
                    if (igCheckbox("Use shadows", &material.useShadows))
                    {
                        igCombo_Str("Shadow filter", &material.shadowFilter, "None\0PCF\0");
                    }
                    igCheckbox("Use fog", &material.useFog);
                    igCheckbox("Use culling", &material.useCulling);
                    igCheckbox("Color write", &material.colorWrite);
                    igCheckbox("Depth write", &material.depthWrite);
                    /*
                    igCheckbox("Output color", &material.outputColor);
                    igCheckbox("Output normals", &material.outputNormal);
                    igCheckbox("Output PBR", &material.outputPBR);
                    igCheckbox("Output emission", &material.outputEmission);
                    */
                    // TODO: parallax mapping settings
                    // TODO: textures
                }
            }

            igEnd();
        }
    }

    // TODO: dynamic array of items
    int[] items = [
        0, 1, 2, 3, 4
    ];
    
    const(char)*[] filenames = [
        "test1.asset",
        "test2.asset",
        "test3.asset",
        "test4.asset",
        "test5.asset"
    ];

    void renderMaterialBrowser()
    {
        ImVec2 size;
        igGetWindowSize(&size);
        float winWidth = size.x;
        int columns = cast(int)(winWidth / 64.0f);
        columns = columns < 1 ? 1 : columns;
        igColumns(columns, null, false);
        foreach(i, item; items)
        {
            igPushID_Int(cast(uint)i);

            igBeginGroup();

            igButton("???", ImVec2(64, 64));

            if (igIsItemHovered() && igIsMouseDoubleClicked(ImGuiMouseButton.Left))
            {
                writeln("Double click ", i);
                // if item is folder, then change directory;
                // if item is file, then apply it to current entity
            }
            else if (igIsItemClicked(ImGuiMouseButton.Right))
            {
                writeln("Right click ", i);
                // show menu
            }

            igTextWrapped("Filename");
            igEndGroup();

            igPopID();
            igNextColumn();
        }
    }

    void renderAssetBrowser()
    {
        if (igBegin("Asset Browser", null, ImGuiWindowFlags.NoCollapse))
        {
            ImVec2 size;
            igGetWindowSize(&size);
            float winWidth = size.x;
            int columns = cast(int)(winWidth / 128.0f);
            columns = columns < 1 ? 1 : columns;
            igColumns(columns, null, false);
            foreach(i, item; items)
            {
                igPushID_Int(cast(uint)i);

                igBeginGroup();

                Texture btnTexture;
                // TODO: thumbnail cache for assets
                if (iconFile) btnTexture = iconFile;
                
                if (btnTexture)
                {
                    ImGuiID btnId = igGetID_Str(filenames[i]);
                    igImageButtonEx(btnId, cast(void*)btnTexture.texture,
                        ImVec2(100, 100), ImVec2(0, 0), ImVec2(1, 1), ImVec2(0, 0), ImVec4(0, 0, 0, 1), ImVec4(1, 1, 1, 1));
                }
                else
                {
                    igButton(filenames[i], ImVec2(100, 100));
                }
                
                if (igBeginDragDropSource())
                {
                    igSetDragDropPayload("ASSET", &items[i], int.sizeof);
                    igText(filenames[i]);
                    igEndDragDropSource();
                }

                if (igIsItemHovered() && igIsMouseDoubleClicked(ImGuiMouseButton.Left))
                {
                    writeln("Double click ", i);
                    // if item is folder, then change directory;
                    // if item is file, then open file with system shell.
                }
                else if (igIsItemClicked(ImGuiMouseButton.Right))
                {
                    writeln("Right click ", i);
                    // show menu
                }

                igTextWrapped(filenames[i]);
                igEndGroup();

                igPopID();
                igNextColumn();
            }
            igEnd();
        }
    }
    
    void renderStatusBar()
    {
        ImGuiWindowFlags windowFlags = ImGuiWindowFlags.NoScrollbar | ImGuiWindowFlags.NoSavedSettings | ImGuiWindowFlags.MenuBar;
        float height = igGetFrameHeight();
        if (igBeginViewportSideBar("##MainStatusBar", viewport, ImGuiDir.Down, height, windowFlags))
        {
            if (igBeginMenuBar())
            {
                // TODO
                igText("Status bar");
                igEndMenuBar();
            }
            igEnd();
        }
    }
    
    void render()
    {
        ImGuiOpenGLBackend.render_draw_data(igGetDrawData());
    }
}
